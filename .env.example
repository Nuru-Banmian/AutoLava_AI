# Copy this file to .env and replace every change-me value before deployment.
AUTOLAVA_DATABASE_URL=mysql+asyncmy://autolava:change-me@host.docker.internal:3306/autolava
AUTOLAVA_JWT_SECRET=change-me-use-a-long-random-secret
AUTOLAVA_COOKIE_SECURE=true
AUTOLAVA_BOOTSTRAP_USERNAME=change-me-admin
AUTOLAVA_BOOTSTRAP_PASSWORD=change-me-use-a-strong-password
